# Copy this file to .env.local and fill in real values.
# These power the contact form's email delivery (app/api/contact/route.ts).

# Any SMTP provider works: Gmail (with an App Password), Outlook, Zoho,
# SendGrid, Resend's SMTP, your web host's mailbox, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where submissions should land — can be the same address as SMTP_USER.
CONTACT_TO_EMAIL=your-email@gmail.com
